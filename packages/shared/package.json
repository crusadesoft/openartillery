    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
