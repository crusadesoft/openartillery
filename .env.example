# ─── HTTP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=2567
PUBLIC_ORIGIN=http://localhost:5173
ENABLE_COLYSEUS_MONITOR=true

# ─── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://artillery:artillery@localhost:5432/artillery

# ─── Redis (Colyseus driver + presence) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Rotate these in production. Generate with `openssl rand -hex 32`.
JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32chars-min
ACCESS_TOKEN_TTL=900      # 15 min (seconds)
REFRESH_TOKEN_TTL=2592000 # 30 days (seconds)
PASSWORD_MIN_LENGTH=8

# ─── Rate limits (per IP) ─────────────────────────────────────────────────────
AUTH_RATE_LIMIT_PER_MIN=10
API_RATE_LIMIT_PER_MIN=120

# ─── Matchmaking ──────────────────────────────────────────────────────────────
DUEL_BOT_FILL_AFTER_MS=20000
REPLAY_RETENTION_HOURS=72

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
METRICS_ENABLED=true
SENTRY_DSN=

# ─── Cosmetics shop (Xsolla) ──────────────────────────────────────────────────
# Pulled from Xsolla Publisher Account → Project Settings.
# MERCHANT_ID + API_KEY authenticate token requests; PROJECT_ID identifies
# the catalog; WEBHOOK_SECRET signs incoming notifications (SHA1).
XSOLLA_MERCHANT_ID=
XSOLLA_PROJECT_ID=
XSOLLA_API_KEY=
XSOLLA_WEBHOOK_SECRET=
# When true, Pay Station opens its sandbox UI and points at sandbox-secure.xsolla.com.
XSOLLA_SANDBOX=true

# Local dev only: skip Xsolla entirely. /api/shop/checkout returns a synthetic
# URL that hits /api/shop/dev-grant and immediately mints the entitlement.
# MUST be false in production — bypasses payment.
SHOP_DEV_MODE=false

# Master kill-switch for paid checkout. When false the catalog still
# renders so players can preview the shop, but the Buy button is disabled
# with a "Coming soon" notice and /api/shop/checkout returns 503. Set to
# false while waiting on Xsolla launch approval.
SHOP_ENABLED=true
